<style>
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
  }

  body {
    background: linear-gradient(180deg, #1a1a1a 0%, #0a0a0a 100%);
    display: flex;
    flex-direction: column;
  }

  .site-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-header {
    position: relative;
    flex: 1;
    padding: 64px 24px;
    text-align: center;
    background: linear-gradient(135deg, rgba(212, 163, 115, 0.05) 0%, rgba(122, 184, 212, 0.05) 100%);
    border-bottom: 1px solid rgba(212, 163, 115, 0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .site-title {
    font-size: 72px;
    margin: 0 0 20px 0;
    color: #e8e8e8;
    font-weight: 700;
    letter-spacing: -2px;
    background: linear-gradient(135deg, #d4a373 0%, #7ab8d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-description {
    font-size: 20px;
    color: #b0b0b0;
    margin: 0;
    line-height: 1.7;
    font-weight: 300;
    max-width: 700px;
  }
</style>

<main class="site-main">
  <div class="post-header">
    <h1 class="site-title">{{ title }}</h1>
    {% if description %}
      <p class="card-description">{{ description }}</p>
    {% endif %}
  </div>
</main>
