---
layout: base.njk
---
<article class="post">
  <div class="post-container">
    <header class="post-header">
      <a href="/posts" class="back-link">← Posts</a>
      <h1>{{ title }}</h1>
      {% if date %}
        <p class="post-meta">
          <time datetime="{{ date }}">
            {{ date | date("YYYY-MM-DD") }}
          </time>
        </p>
      {% endif %}
      <span class="meta__stats">About {{ content | readingTime }} reading time</span>
    </header>
    <div class="post-content">
      {{ content | safe }}
    </div>
  </div>
</article>
