{
    auto_https off
}

:8080 {

    root * /usr/share/caddy
    file_server

    handle_errors {
        @404 {
            expression {http.error.status_code} == 404
        }
        rewrite @404 /404.html

        @error {
            expression {http.error.status_code} >= 400
        }
        rewrite @error /error.html

        file_server
    }
}
